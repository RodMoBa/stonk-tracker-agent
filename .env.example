# Optional override. Leave empty to use DB_* settings or SQLITE_DATABASE_URL.
DATABASE_URL=
SQLITE_DATABASE_URL=sqlite:///./stonk_tracker_local.db

# SQL Server settings. If MSSQL_SERVER and MSSQL_STONK_DB are set, the app builds the
# mssql+pyodbc URL internally and safely handles special characters in passwords.
MSSQL_SERVER=
DB_PORT=1433
MSSQL_STONK_DB=
MSSQL_USER_WB=
MSSQL_PASS_WB=
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_TRUST_SERVER_CERTIFICATE=true
DB_ENCRYPT=true

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano

ALPHA_VANTAGE_API_KEY=

# V1 web-search adapter uses Tavily's HTTP API when this key is present.
TAVILY_API_KEY=

REPORTS_DIR=reports
APP_TIMEZONE=Europe/Madrid
