# Optional override. Leave empty to use DB_* settings or SQLITE_DATABASE_URL.
DATABASE_URL=
SQLITE_DATABASE_URL=sqlite:///./stonk_tracker_local.db

# SQL Server settings. If DB_SERVER and DB_NAME are set, the app builds the
# mssql+pyodbc URL internally and safely handles special characters in passwords.
DB_SERVER=
DB_PORT=1433
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_TRUST_SERVER_CERTIFICATE=true
DB_ENCRYPT=true

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano

ALPHA_VANTAGE_API_KEY=

# V1 web-search adapter uses Tavily's HTTP API when this key is present.
TAVILY_API_KEY=

REPORTS_DIR=reports
APP_TIMEZONE=Europe/Madrid
